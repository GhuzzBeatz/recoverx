{
  "name": "recoverx",
  "version": "1.0.2",
  "description": "RecoverX - Recuperacao Profissional de Arquivos",
  "main": "main.js",
  "author": "GHZ Plugin",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.ghzplugin.recoverx",
    "productName": "RecoverX",
    "directories": {
      "output": "dist_installer"
    },
    "files": [
      "**/*",
      "!dist_installer/**",
      "!node_modules/.cache/**"
    ],
    "extraResources": [
      {
        "from": "tools/",
        "to": "tools/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RecoverX"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {}
}
